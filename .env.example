# ── Supabase ────────────────────────────────────────────────────────
# Projeto da plataforma de gestão. É o MESMO projeto usado pelo site
# (trevocode.com) para gravar leads — assim os contatos caem no CRM.
# Copie de Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role (Settings → API) — usada só no servidor / seed. Nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Allowlist da área interna ───────────────────────────────────────
# E-mails autorizados a acessar a plataforma, separados por vírgula.
# Só estes entram, mesmo com conta criada no Supabase.
INTERNAL_ALLOWED_EMAILS=fabricio@trevocode.com,yuri@trevocode.com

# ── Máquina de prospecção (API HTTP de ações) ───────────────────────
# A plataforma dispara ações (capturar, gerar isca, enfileirar, etc.) via
# POST na API da máquina. NUNCA escreve direto nas tabelas prospect.*.
# Em dev a máquina roda em http://localhost:8080 (npm run serve no repo
# trevocode-prospect). O token tem que ser IGUAL ao PROSPECT_API_TOKEN
# do .env da máquina. Ambos ficam só no servidor (nunca NEXT_PUBLIC).
PROSPECT_API_URL=http://localhost:8080
PROSPECT_API_TOKEN=
